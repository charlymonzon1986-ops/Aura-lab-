{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and subscription information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "plan": { "type": "string", "enum": ["free", "pro", "studio"] },
        "storageUsed": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "plan"]
    },
    "Photo": {
      "title": "Photo",
      "description": "Photo metadata and lighting settings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "url": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "settings": { "type": "object" },
        "isPublic": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "url", "settings"]
    },
    "Preset": {
      "title": "Preset",
      "description": "Saved lighting presets",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "settings": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "name", "settings"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/photos/{photoId}": {
      "schema": "Photo",
      "description": "Photos stored in the system"
    },
    "/presets/{presetId}": {
      "schema": "Preset",
      "description": "User saved presets"
    }
  }
}
