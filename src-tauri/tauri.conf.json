{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:3000",
    "distDir": "../dist",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "Aura Lab",
    "version": "1.3.1"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "path": {
        "all": true
      },
      "dialog": {
        "all": true
      },
      "fs": {
        "all": true,
        "scope": ["$APP/*", "$HOME/Pictures/*"]
      }
    },
    "bundle": {
      "active": true,
      "targets": ["msi", "appimage", "dmg"],
      "identifier": "com.auralab.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "publisher": "Aura Lab",
      "updater": {
        "active": true,
        "endpoints": [
          "https://raw.githubusercontent.com/username/repo/main/updater.json"
        ],
        "dialog": true,
        "pubkey": "REPLACE_WITH_YOUR_PUBLIC_KEY"
      },
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampServer": "http://timestamp.digicert.com"
      }
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:;"
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Aura Lab - Professional Editor",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 720,
        "theme": "Dark"
      }
    ]
  }
}
