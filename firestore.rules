rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      let adminEmails = ["juanomonzon@gmail.com", "charlymonzon.1986@gmail.com", "socia@example.com", "ruth1094@gmail.com"];
      return isAuthenticated() && 
        (
          (request.auth.token.email != null && request.auth.token.email.lower() in adminEmails && request.auth.token.email_verified == true) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'plan']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'] &&
             data.plan in ['free', 'pro', 'studio'];
    }

    function isValidPhoto(data) {
      return data.keys().hasAll(['userId', 'url', 'settings']) &&
             data.userId == request.auth.uid &&
             data.url is string &&
             data.url.size() < 2000000;
    }

    function isValidFolder(data) {
      return data.keys().hasAll(['id', 'userId', 'name']) &&
             data.id is string &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    match /photos/{photoId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.isPublic == true || isAdmin());
      allow create: if isAuthenticated() && isValidPhoto(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /presets/{presetId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.isSystem == true || isAdmin());
      allow create: if isAuthenticated() && (
        (request.resource.data.isSystem == false && request.resource.data.userId == request.auth.uid) ||
        (request.resource.data.isSystem == true && isAdmin())
      );
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /folders/{folderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidFolder(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidFolder(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
