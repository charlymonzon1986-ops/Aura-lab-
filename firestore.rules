rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // In this environment, we check for verified emails.
      // We should avoid hardcoding, but since we can't use env vars in rules, 
      // we check for a specific admin flag on the user document if possible,
      // or at least require verification.
      return isAuthenticated() && 
             request.auth.token.email_verified == true && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'plan']) &&
             data.uid is string &&
             data.email is string;
    }

    function isValidPhoto(data) {
      return data.keys().hasAll(['userId', 'url', 'settings', 'size']) &&
             data.userId == request.auth.uid &&
             data.url is string &&
             data.size is int &&
             data.size < 524288000; // 500MB limit per file
    }

    function isValidFolder(data) {
      return data.keys().hasAll(['userId', 'name']) &&
             data.userId == request.auth.uid &&
             data.name is string &&
             data.name.size() > 0 && data.name.size() <= 100;
    }

    function isValidClient(data) {
      return data.keys().hasAll(['userId', 'name']) &&
             data.userId == request.auth.uid &&
             data.name is string &&
             data.name.size() > 0 && data.name.size() <= 100;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (isAdmin() || isOwner(userId));
    }

    match /photos/{photoId} {
      allow read: if (resource.data.isPublic == true) || 
                     (isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()));
      allow create: if isAuthenticated() && isValidPhoto(request.resource.data);
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /presets/{presetId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.isSystem == true || isAdmin());
      allow create: if isAuthenticated() && (
        (request.resource.data.isSystem == false && request.resource.data.userId == request.auth.uid) ||
        (request.resource.data.isSystem == true && isAdmin())
      );
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /folders/{folderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidFolder(request.resource.data);
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /photos/{photoId}/versions/{versionId} {
      allow read, create, delete: if isAuthenticated() && (get(/databases/$(database)/documents/photos/$(photoId)).data.userId == request.auth.uid || isAdmin());
    }

    match /clients/{clientId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /galleries/{galleryId} {
      allow read: if (isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin())) || 
                    (resource.data.status == 'published');
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
