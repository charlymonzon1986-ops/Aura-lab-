rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      let adminEmails = ["juanomonzon@gmail.com", "charlymonzon.1986@gmail.com", "socia@example.com", "ruth1094@gmail.com"];
      return isAuthenticated() && 
             request.auth.token.email_verified == true && 
             request.auth.token.email.lower() in adminEmails;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'plan']) &&
             data.uid is string &&
             data.email is string;
    }

    function isValidPhoto(data) {
      return data.keys().hasAll(['userId', 'url', 'settings']) &&
             data.userId == request.auth.uid &&
             data.url is string;
    }

    function isValidFolder(data) {
      return data.keys().hasAll(['id', 'userId', 'name']) &&
             data.id is string &&
             data.userId == request.auth.uid &&
             data.name is string;
    }

    function isValidClient(data) {
      return data.keys().hasAll(['id', 'userId', 'name']) &&
             data.userId == request.auth.uid &&
             data.name is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (isAdmin() || isOwner(userId));
    }

    match /photos/{photoId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.isPublic == true || isAdmin());
      allow create: if isAuthenticated() && isValidPhoto(request.resource.data);
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /presets/{presetId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.isSystem == true || isAdmin());
      allow create: if isAuthenticated() && (
        (request.resource.data.isSystem == false && request.resource.data.userId == request.auth.uid) ||
        (request.resource.data.isSystem == true && isAdmin())
      );
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /folders/{folderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidFolder(request.resource.data);
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /photos/{photoId}/versions/{versionId} {
      allow read, create, delete: if isAuthenticated() && (get(/databases/$(database)/documents/photos/$(photoId)).data.userId == request.auth.uid || isAdmin());
    }

    match /clients/{clientId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /galleries/{galleryId} {
      allow read: if (isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin())) || 
                    (resource.data.status == 'published');
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
